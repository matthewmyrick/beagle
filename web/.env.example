# GitHub SSO for the optional auth gateway (docker compose --profile auth).
# Copy to .env and fill in. Bring your own GitHub OAuth app:
#   GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   Authorization callback URL:  https://<your-host>/oauth2/callback
#                                (or http://localhost:4180/oauth2/callback for local)

GITHUB_CLIENT_ID=your-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-oauth-app-client-secret

# 32-byte base64 cookie secret:  openssl rand -base64 32
COOKIE_SECRET=

# The callback URL registered on the OAuth app.
OAUTH2_REDIRECT_URL=http://localhost:4180/oauth2/callback

# Restrict who may view (optional; blank = any authenticated GitHub user).
GITHUB_ORG=
GITHUB_TEAM=

# Set to true when serving over HTTPS.
COOKIE_SECURE=false
